---
interface Props {
	code: string;
}

const { code } = Astro.props;
---

<div class="relative group mermaid-wrapper my-4">
	<div class="mermaid-block flex justify-center bg-[var(--card-bg)] rounded-xl p-4 md:p-6 border border-black/10 dark:border-white/5 shadow-md overflow-x-auto" data-mermaid-code={code}>
		<div class="animate-pulse w-full h-32 flex items-center justify-center text-sm text-[var(--text-color-light)]">
			Rendering diagram...
		</div>
	</div>
	<!-- Fullscreen Zoom Button -->
	<button class="mermaid-fullscreen-btn absolute bottom-3 right-3 p-1.5 rounded-lg bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 opacity-0 group-hover:opacity-100 transition-all duration-200 focus:opacity-100 shadow-sm border border-black/5 dark:border-white/5 backdrop-blur-sm" title="全屏放大">
		<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
		</svg>
	</button>
</div>

<style is:global>
.mermaid-block,
.mermaid-block * {
	transition: none !important;
}
</style>

<script>
	// Fullscreen Modal for Mermaid Diagrams
	document.addEventListener("click", (e) => {
		const target = e.target as HTMLElement;
		const btn = target?.closest(".mermaid-fullscreen-btn");
		if (!btn) return;

		const block = btn.closest(".mermaid-wrapper")?.querySelector(".mermaid-block");
		if (!block) return;

		const svg = block.querySelector("svg");
		if (!svg) return;

		// Create fullscreen overlay
		const overlay = document.createElement("div");
		overlay.className = "fixed inset-0 z-[9999] flex items-center justify-center bg-black/85 backdrop-blur-md p-4 cursor-zoom-out opacity-0 transition-opacity duration-200";
		
		const container = document.createElement("div");
		container.className = "w-[90vw] max-w-[90vw] max-h-[90vh] bg-[var(--card-bg)] p-6 md:p-10 rounded-2xl shadow-2xl overflow-auto border border-black/10 dark:border-white/5 relative cursor-default transition-all duration-200 transform scale-95 opacity-0 flex flex-col items-center justify-center";
		
		// Clone SVG and modify size for fullscreen
		const clonedSvg = svg.cloneNode(true) as SVGElement;
		clonedSvg.removeAttribute("style"); // Remove Mermaid's inline styles (including max-width)
		clonedSvg.style.width = "100%";
		clonedSvg.style.maxWidth = "100%";
		clonedSvg.style.height = "auto";
		clonedSvg.style.maxHeight = "75vh";
		
		// Close button inside container
		const closeBtn = document.createElement("button");
		closeBtn.className = "absolute top-4 right-4 p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/5 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transition-colors";
		closeBtn.innerHTML = `
			<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		`;
		
		container.appendChild(clonedSvg);
		container.appendChild(closeBtn);
		overlay.appendChild(container);
		document.body.appendChild(overlay);

		// Force reflow and animate in
		requestAnimationFrame(() => {
			overlay.classList.remove("opacity-0");
			container.classList.remove("scale-95", "opacity-0");
		});

		// Prevent body scroll
		document.body.style.overflow = "hidden";

		// Close handler
		const close = () => {
			overlay.classList.add("opacity-0");
			container.classList.add("scale-95", "opacity-0");
			setTimeout(() => {
				overlay.remove();
				document.body.style.overflow = "";
			}, 200);
		};

		overlay.addEventListener("click", (evt) => {
			if (evt.target === overlay) close();
		});
		closeBtn.addEventListener("click", close);
		
		// ESC key listener
		const escHandler = (evt: KeyboardEvent) => {
			if (evt.key === "Escape") {
				close();
				document.removeEventListener("keydown", escHandler);
			}
		};
		document.addEventListener("keydown", escHandler);
	});
</script>
