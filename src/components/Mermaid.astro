---
import fs from 'fs';
import path from 'path';
import crypto from 'crypto';

interface Props {
	code: string;
}

const { code } = Astro.props;

// Cache directory path
const CACHE_DIR = path.resolve('.astro', 'mermaid-cache');

async function getStaticSvg(diagramCode: string, theme: string) {
	// Ensure cache directory exists
	if (!fs.existsSync(CACHE_DIR)) {
		fs.mkdirSync(CACHE_DIR, { recursive: true });
	}

	const hash = crypto.createHash('sha256').update(diagramCode + '|' + theme).digest('hex');
	const cachePath = path.join(CACHE_DIR, `${hash}.svg`);

	if (fs.existsSync(cachePath)) {
		return fs.readFileSync(cachePath, 'utf-8');
	}

	// Prepare code with theme directive
	const themeDirective = `%%{init: { "theme": "${theme}" }}%%\n`;
	const fullCode = themeDirective + diagramCode;

	const response = await fetch("https://kroki.io/mermaid/svg", {
		method: "POST",
		headers: {
			"Content-Type": "text/plain",
		},
		body: fullCode,
	});

	if (!response.ok) {
		throw new Error(`Kroki render failed: ${response.status} ${response.statusText}`);
	}

	const svg = await response.text();
	fs.writeFileSync(cachePath, svg, 'utf-8');
	return svg;
}

let lightSvg = "";
let darkSvg = "";
let errorMsg = "";

try {
	lightSvg = await getStaticSvg(code, "default");
	darkSvg = await getStaticSvg(code, "dark");
} catch (e: any) {
	console.error("Failed to render Mermaid statically:", e);
	errorMsg = e.message || String(e);
}
---

<div class="relative group mermaid-wrapper my-4">
	<div class="mermaid-block flex justify-center bg-[var(--card-bg)] rounded-xl p-4 md:p-6 border border-black/10 dark:border-white/5 shadow-md overflow-x-auto">
		{errorMsg ? (
			<div class="text-red-500 text-sm p-4 bg-red-100 dark:bg-red-950 border border-red-200 dark:border-red-900 rounded-xl font-mono whitespace-pre-wrap">
				Static Mermaid Render Failed: {errorMsg}
			</div>
		) : (
			<div class="w-full flex justify-center">
				<div class="block dark:hidden w-full class-light-svg" set:html={lightSvg} />
				<div class="hidden dark:block w-full class-dark-svg" set:html={darkSvg} />
			</div>
		)}
	</div>
	
	<!-- Fullscreen Zoom Button -->
	{!errorMsg && (
		<button class="mermaid-fullscreen-btn absolute bottom-3 right-3 p-1.5 rounded-lg bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 opacity-0 group-hover:opacity-100 transition-all duration-200 focus:opacity-100 shadow-sm border border-black/5 dark:border-white/5 backdrop-blur-sm" title="全屏放大">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
			</svg>
		</button>
	)}

	<!-- Pre-rendered Fullscreen Zoom Modal (Hidden by default, static SVG inside) -->
	{!errorMsg && (
		<div class="mermaid-modal-overlay hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/85 backdrop-blur-md p-4 cursor-zoom-out opacity-0 transition-opacity duration-200">
			<div class="mermaid-modal-container w-[90vw] max-w-[90vw] max-h-[90vh] bg-[var(--card-bg)] p-6 md:p-10 rounded-2xl shadow-2xl overflow-auto border border-black/10 dark:border-white/5 relative cursor-default transition-opacity duration-200 opacity-0 flex flex-col items-center justify-center">
				<div class="w-full flex justify-center">
					<div class="block dark:hidden w-full class-light-svg-zoom" set:html={lightSvg} />
					<div class="hidden dark:block w-full class-dark-svg-zoom" set:html={darkSvg} />
				</div>
				<button class="mermaid-modal-close-btn absolute top-4 right-4 p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/5 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
		</div>
	)}
</div>

<style is:global>
.class-light-svg-zoom svg,
.class-dark-svg-zoom svg {
	width: 100% !important;
	max-width: 100% !important;
	height: auto !important;
	max-height: 75vh !important;
}
.mermaid-block,
.mermaid-block * {
	transition: none !important;
}
</style>

<script>
	// Fullscreen Modal for Mermaid Diagrams (Static delegation, no DOM creation at runtime)
	document.addEventListener("click", (e) => {
		const target = e.target as HTMLElement;
		
		// Handle open modal
		const openBtn = target?.closest(".mermaid-fullscreen-btn");
		if (openBtn) {
			const wrapper = openBtn.closest(".mermaid-wrapper");
			const overlay = wrapper?.querySelector(".mermaid-modal-overlay") as HTMLElement;
			const container = wrapper?.querySelector(".mermaid-modal-container") as HTMLElement;
			if (!overlay || !container) return;

			overlay.classList.remove("hidden");
			// Prevent body scroll
			document.body.style.overflow = "hidden";

			// Force reflow and animate in
			requestAnimationFrame(() => {
				overlay.classList.remove("opacity-0");
				container.classList.remove("opacity-0");
			});
			return;
		}

		// Handle close modal (click on overlay or close button)
		const overlay = target.closest(".mermaid-modal-overlay") as HTMLElement;
		if (overlay) {
			const closeBtn = target.closest(".mermaid-modal-close-btn");
			// If clicked on overlay itself (outside container) or clicked close button
			if (target === overlay || closeBtn) {
				const container = overlay.querySelector(".mermaid-modal-container") as HTMLElement;
				if (!container) return;

				overlay.classList.add("opacity-0");
				container.classList.add("opacity-0");
				
				setTimeout(() => {
					overlay.classList.add("hidden");
					document.body.style.overflow = "";
				}, 200);
			}
		}
	});

	// ESC key listener to close active modal
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") {
			const openOverlay = document.querySelector(".mermaid-modal-overlay:not(.hidden)") as HTMLElement;
			if (!openOverlay) return;

			const container = openOverlay.querySelector(".mermaid-modal-container") as HTMLElement;
			if (container) {
				openOverlay.classList.add("opacity-0");
				container.classList.add("opacity-0");
				
				setTimeout(() => {
					openOverlay.classList.add("hidden");
					document.body.style.overflow = "";
				}, 200);
			}
		}
	});
</script>
