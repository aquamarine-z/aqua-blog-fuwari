---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getBlogCategoryList, getDocsCategoryTree } from "../../utils/content-utils";
import ButtonLink from "../control/ButtonLink.astro";
import WidgetLayout from "./WidgetLayout.astro";
import CategoryTree from "./CategoryTree.svelte";

interface Props {
	class?: string;
	style?: string;
	isDocs?: boolean;
}
const className = Astro.props.class;
const style = Astro.props.style;
const isDocs = Astro.props.isDocs;

let categories = [];
let categoryTree = [];
if (isDocs) {
	categoryTree = await getDocsCategoryTree();
} else {
	categories = await getBlogCategoryList();
}

const COLLAPSED_HEIGHT = "7.5rem";
const COLLAPSE_THRESHOLD = 5;

// If it's the tree view, we don't collapse the widget
const isCollapsed = !isDocs && categories.length >= COLLAPSE_THRESHOLD;
---

<WidgetLayout name={i18n(I18nKey.categories, Astro.currentLocale)} id="categories" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style}
>
	{isDocs ? (
		<CategoryTree client:load categories={categoryTree} lang={Astro.currentLocale} currentUrl={Astro.url.pathname} />
	) : (
		categories.map((c) =>
			<ButtonLink
				url={c.url}
				badge={String(c.count)}
				label={`View all posts in the ${c.name.trim()} category`}
			>
				{c.name.trim()}
			</ButtonLink>
		)
	)}
</WidgetLayout>

