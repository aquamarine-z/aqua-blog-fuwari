---
import type { MarkdownHeading } from "astro";
import { stripBasePath } from "../../utils/url-utils";
import Categories from "./Categories.astro";
import DocsDirectory from "./DocsDirectory.astro";
import Profile from "./Profile.astro";
import Tag from "./Tags.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const className = Astro.props.class;
const currentPath = stripBasePath(Astro.url.pathname);
const isDocs =
	/^\/([a-zA-Z_-]+\/)?docs\/?/.test(currentPath) ||
	currentPath.includes("/posts/docs");
---
<div id="sidebar" class:list={[className, "w-full"]}>
    <div class:list={["flex flex-col w-full gap-4 mb-4", {"hidden lg:flex": isDocs}]}>
        <Profile></Profile>
    </div>
    <div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4">
        {isDocs ? (
            <DocsDirectory class="onload-animation" style="animation-delay: 150ms" />
        ) : (
            <>
                <Categories class="onload-animation" style="animation-delay: 150ms" />
                <Tag class="onload-animation" style="animation-delay: 200ms" isDocs={false}></Tag>
            </>
        )}
    </div>
</div>

<script>
import { stripBasePath } from "../../utils/url-utils";

function isDocsPath(pathname) {
    pathname = stripBasePath(pathname);
    return /^\/([a-zA-Z_-]+\/)?docs\/?/.test(pathname) || pathname.includes('/posts/docs');
}

async function refreshSidebarSticky(targetUrl) {
    const currentSidebarRoot = document.getElementById('sidebar');
    const currentSidebar = document.getElementById('sidebar-sticky');
    if (!currentSidebar) return;

    try {
        const response = await fetch(targetUrl, {
            headers: { 'X-Requested-With': 'swup-sidebar-sync' },
        });
        if (!response.ok) return;

        const html = await response.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const nextSidebarRoot = doc.getElementById('sidebar');
        const nextSidebar = doc.getElementById('sidebar-sticky');
        if (!nextSidebar) return;

        if (currentSidebarRoot && nextSidebarRoot) {
            currentSidebarRoot.className = nextSidebarRoot.className;

            const currentProfileWrapper = currentSidebarRoot.querySelector(':scope > div:first-child');
            const nextProfileWrapper = nextSidebarRoot.querySelector(':scope > div:first-child');
            if (currentProfileWrapper && nextProfileWrapper) {
                currentProfileWrapper.className = nextProfileWrapper.className;
            }
        }

        currentSidebar.replaceWith(nextSidebar);
    } catch (error) {
        console.warn('Failed to sync sidebar widgets:', error);
    }
}

function setupSidebarSync() {
    if (window.__sidebarSyncMounted) return;
    window.__sidebarSyncMounted = true;

    let previousPath = stripBasePath(window.location.pathname);
    let pendingSync = false;

    const syncIfSidebarShouldRefresh = () => {
        const nextPath = stripBasePath(window.location.pathname);
        if (nextPath === previousPath) return;

        const wasDocsPath = isDocsPath(previousPath);
        const isNextDocsPath = isDocsPath(nextPath);
        const isDocsInternalNavigation = wasDocsPath && isNextDocsPath;
        const shouldRefresh = wasDocsPath !== isNextDocsPath;
        previousPath = nextPath;

        if (shouldRefresh) {
            refreshSidebarSticky(`${window.location.pathname}${window.location.search}`);
            return;
        }

        if (isDocsInternalNavigation) {
            document.dispatchEvent(new CustomEvent('docs-directory:update-url', {
                detail: { url: nextPath },
            }));
            document.dispatchEvent(new CustomEvent('category-tree:update-url', {
                detail: { url: nextPath },
            }));
        }
    };

    const scheduleSidebarSync = () => {
        if (pendingSync) return;
        pendingSync = true;

        requestAnimationFrame(() => {
            pendingSync = false;
            syncIfSidebarShouldRefresh();
        });
    };

    document.addEventListener('astro:page-load', scheduleSidebarSync);
    document.addEventListener('swup:content:replace', scheduleSidebarSync);
    document.addEventListener('swup:page:view', scheduleSidebarSync);
    window.addEventListener('popstate', scheduleSidebarSync);
}

setupSidebarSync();
</script>
