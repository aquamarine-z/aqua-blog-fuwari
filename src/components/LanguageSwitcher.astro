---
import { Icon } from "astro-icon/components";

const currentLang = Astro.currentLocale || "zh_CN";

const languages = [
    { code: "zh_CN", name: "简体中文", path: "/" },
    { code: "en", name: "English", path: "/en/" },
    { code: "ja", name: "日本語", path: "/ja/" },
    { code: "ko", name: "한국어", path: "/ko/" }
];

const currentLangName = languages.find(l => l.code === currentLang)?.name || "简体中文";

// Build switch URLs for each language
const { pathname } = Astro.url;
const langUrls = languages.map(lang => {
    // First, strip any existing language prefix (/en, /ja, /ko) to get the base path
    let basePath = pathname.replace(/^\/(en|ja|ko)(\/|$)/, "/");
    if (!basePath.startsWith("/")) basePath = "/" + basePath;
    
    let targetUrl = basePath;
    if (lang.code !== "zh_CN") {
        // Prepend the new language code
        targetUrl = `/${lang.code}${basePath === '/' ? '/' : basePath}`;
    }
    return { ...lang, url: targetUrl, active: lang.code === currentLang };
});
---

<lang-switcher class="relative">
    <button aria-label="Switch Language" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90 flex items-center justify-center" id="lang-switch-btn" title="Switch Language">
        <Icon name="material-symbols:translate" class="text-[1.25rem]"></Icon>
    </button>
    <div id="lang-panel" class="float-panel-closed absolute right-0 top-[3.25rem] z-50 min-w-[8rem] rounded-xl card-base p-1 shadow-lg transition-all duration-200 origin-top-right">
        {langUrls.map((lang) => (
            <a href={lang.url} data-no-swup data-lang-code={lang.code}
               class:list={[
                   "flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition-colors cursor-pointer",
                   lang.active
                       ? "text-[var(--primary)] bg-[var(--btn-plain-bg-hover)] font-bold"
                       : "text-neutral-700 dark:text-neutral-300 hover:bg-[var(--btn-plain-bg-hover)] hover:text-[var(--primary)]"
               ]}
            >
                {lang.active && <Icon name="material-symbols:check-rounded" class="text-[1rem]" />}
                <span>{lang.name}</span>
            </a>
        ))}
    </div>
</lang-switcher>

<style>
    .float-panel-closed {
        opacity: 0;
        transform: scale(0.95);
        pointer-events: none;
    }
    #lang-panel:not(.float-panel-closed) {
        opacity: 1;
        transform: scale(1);
        pointer-events: auto;
    }
</style>

<script>
class LangSwitcher extends HTMLElement {
    constructor() {
        super();
        const btn = this.querySelector('#lang-switch-btn');
        const panel = this.querySelector('#lang-panel');

        if (btn && panel) {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                panel.classList.toggle('float-panel-closed');
            });

            // Close when clicking outside
            document.addEventListener('click', (e) => {
                if (!this.contains(e.target)) {
                    panel.classList.add('float-panel-closed');
                }
            });

            // Close on escape key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    panel.classList.add('float-panel-closed');
                }
            });
            
            // Update links on client-side navigation
            const updateLinks = () => {
                const currentPath = window.location.pathname;
                // Get base path by stripping any known prefix
                let basePath = currentPath.replace(/^\/(en|ja|ko)(\/|$)/, "/");
                if (!basePath.startsWith("/")) basePath = "/" + basePath;

                const links = this.querySelectorAll('a[data-lang-code]');
                links.forEach(a => {
                    const code = a.getAttribute('data-lang-code');
                    let targetUrl = basePath;
                    if (code !== 'zh_CN') {
                        targetUrl = `/${code}${basePath === '/' ? '/' : basePath}`;
                    }
                    a.setAttribute('href', targetUrl);
                });
            };
            
            // Listen for Swup transitions
            const setupSwup = () => {
                window.swup.hooks.on('content:replace', updateLinks);
            };
            if (window?.swup?.hooks) {
                setupSwup();
            } else {
                document.addEventListener('swup:enable', setupSwup);
            }
            
            // Also run once on mount in case it's a client-rendered component
            updateLinks();
        }
    }
}

if (!customElements.get('lang-switcher')) {
    customElements.define('lang-switcher', LangSwitcher);
}
</script>
