---
import { getLangPaths } from '@utils/i18n-utils';
import type { GetStaticPaths } from "astro";
import Pagination from "../../../components/control/Pagination.astro";
import PostPage from "../../../components/PostPage.astro";
import { PAGE_SIZE } from "../../../constants/constants";
import MainGridLayout from "../../../layouts/MainGridLayout.astro";
import { getSortedDocsPosts } from "../../../utils/content-utils";
export const getStaticPaths = (async ({ paginate }) => {
	const allDocsPosts = await getSortedDocsPosts();
	const langPaths = getLangPaths();
	return langPaths.flatMap(lang => 
		paginate(allDocsPosts, { pageSize: PAGE_SIZE, params: { lang: lang.params.lang || undefined } })
	);
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const len = page.data.length;
---

<MainGridLayout title={i18n(I18nKey.docs, Astro.currentLocale)}>
    <PostPage page={page}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
</MainGridLayout>
