---
import { getLangPaths } from '@utils/i18n-utils';

import path from "node:path";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n, getTranslation } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedBlogPosts } from "@utils/content-utils";
import { getDir, getPostUrlBySlug, url } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig, giscusConfig } from "src/config";
import ImageWrapper from "../../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../../components/PostMeta.astro";
import { profileConfig, siteConfig } from "../../../config";
import { formatDateToYYYYMMDD } from "../../../utils/date-utils";
import TOC from "@components/widget/TOC.astro";
import Giscus from "@components/Giscus.astro";

import { getBlogCategoryTree, flattenTreeSlugs } from "@utils/content-utils";

export async function getStaticPaths() {
	const langPaths = getLangPaths();
	return Promise.all(langPaths.map(async (lang) => {
		const langCode = lang.params.lang || siteConfig.lang;
		const allEntries = await getSortedBlogPosts(langCode, true);
		const tree = await getBlogCategoryTree(langCode);
		const slugs = flattenTreeSlugs(tree);
		
		const visibleEntries = allEntries.filter(entry => entry.availableLangs?.includes(langCode) || entry.availableLangs?.includes(siteConfig.lang));
		for (let i = 0; i < visibleEntries.length; i++) {
			const entry = visibleEntries[i];
			if (i > 0) {
				const prev = visibleEntries[i - 1];
				entry.data.prevSlug = prev.slug;
				entry.data.prevTitle = prev.data.title;
			}
			if (i < visibleEntries.length - 1) {
				const next = visibleEntries[i + 1];
				entry.data.nextSlug = next.slug;
				entry.data.nextTitle = next.data.title;
			}
		}

		const hiddenEntries = allEntries.filter(entry => !entry.availableLangs?.includes(langCode) && !entry.availableLangs?.includes(siteConfig.lang));
		for (const entry of hiddenEntries) {
			entry.data.prevSlug = "";
			entry.data.prevTitle = "";
			entry.data.nextSlug = "";
			entry.data.nextTitle = "";
		}

		return allEntries.map((entry) => {
			return {
				params: { lang: lang.params.lang || undefined, slug: entry.slug },
				props: { entry },
			};
		});
	})).then(results => results.flat());
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const { remarkPluginFrontmatter } = await entry.render();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: (Astro.currentLocale || siteConfig.lang).replace("_", "-"),
	// TODO include cover image here
};
---
<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={Astro.currentLocale || siteConfig.lang} setOGTypeArticle={true} headings={headings}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <div id="post-container" class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full" data-available-langs={entry.availableLangs ? entry.availableLangs.join(',') : ''}>
            <!-- word count and reading time -->
            <div class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation">
                <div class="flex flex-row items-center">
                    <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
                        <Icon name="material-symbols:notes-rounded"></Icon>
                    </div>
                    <div class="text-sm">{remarkPluginFrontmatter.words} {" " + i18n(remarkPluginFrontmatter.words === 1 ? I18nKey.wordCount : I18nKey.wordsCount, Astro.currentLocale)}</div>
                </div>
                <div class="flex flex-row items-center">
                    <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
                        <Icon name="material-symbols:schedule-outline-rounded"></Icon>
                    </div>
                    <div class="text-sm">
                        {remarkPluginFrontmatter.minutes} {" " + i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount, Astro.currentLocale)}
                    </div>
                </div>
            </div>

            <!-- title -->
            <div class="relative onload-animation">
                <div
                    data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title"
                    class="transition w-full block font-bold mb-3
                    text-3xl md:text-[2.25rem]/[2.75rem]
                    text-black/90 dark:text-white/90
                    md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
                    before:absolute before:top-[0.75rem] before:left-[-1.125rem]
                ">
                    {entry.data.title}
                </div>
            </div>

            <!-- metadata -->
            <div class="onload-animation">
                <PostMetadata
                        class="mb-5"
                        published={entry.data.published}
                        updated={entry.data.updated}
                        tags={entry.data.tags}
                        category={entry.data.category}
                        type="blog"
                ></PostMetadata>

                {entry.availableLangs && entry.availableLangs.length > 0 && (
                    <div class="flex flex-wrap items-center gap-2 mb-5 mt-2">
                        <Icon name="material-symbols:translate-rounded" class="text-xl text-black/40 dark:text-white/40 mr-1" />
                        {entry.availableLangs.sort((a: string, b: string) => {
                            const langs = siteConfig.languages || [siteConfig.lang, "en", "ja", "ko"];
                            const iA = langs.indexOf(a);
                            const iB = langs.indexOf(b);
                            return (iA === -1 ? 999 : iA) - (iB === -1 ? 999 : iB);
                        }).map((l: string) => {
                            const isMain = l === siteConfig.lang;
                            const link = isMain ? url(`/posts/${entry.slug}/`) : url(`/${l}/posts/${entry.slug}/`);
                            const isCurrent = l === (Astro.currentLocale || siteConfig.lang);
                            return (
                                <a href={link} data-no-swup class:list={[
                                    "px-3 py-1 rounded-lg text-sm font-medium transition-colors",
                                    isCurrent 
                                        ? "bg-[var(--primary)] text-white dark:text-black pointer-events-none" 
                                        : "bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20"
                                ]}>
                                    {getTranslation(l)?.[I18nKey.name] || l}
                                </a>
                            );
                        })}
                    </div>
                )}

                {!entry.data.image && <div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-5"></div>}
            </div>

            <!-- always show cover as long as it has one -->

            {entry.data.image &&
                <ImageWrapper id="post-cover" src={entry.data.image} basePath={path.join("content", entry.collection, getDir(entry.id))} class="mb-8 rounded-xl banner-container onload-animation"/>
            }

            {entry.isFallback && entry.originalLang === siteConfig.lang && (
                <div class="mb-6 p-4 rounded-xl bg-orange-500/10 text-orange-600 dark:text-orange-400 border border-orange-500/20 onload-animation">
                    <div class="flex items-center gap-2">
                        <Icon name="material-symbols:warning-outline-rounded" class="text-xl" />
                        <span>{i18n(I18nKey.fallbackToMainLang, Astro.currentLocale)}</span>
                    </div>
                </div>
            )}
            
            {entry.isFallback && entry.originalLang !== siteConfig.lang && (
                <div class="mb-6 p-4 rounded-xl bg-red-500/10 text-red-600 dark:text-red-400 border border-red-500/20 onload-animation">
                    <div class="flex items-center gap-2 mb-2">
                        <Icon name="material-symbols:error-outline-rounded" class="text-xl" />
                        <span>{i18n(I18nKey.noTranslationSwitchTo, Astro.currentLocale)}</span>
                    </div>
                    <div class="flex flex-wrap gap-2 mt-2">
                        {entry.availableLangs && entry.availableLangs.map(l => {
                            const isMain = l === siteConfig.lang;
                            const link = isMain ? url(`/posts/${entry.slug}/`) : url(`/${l}/posts/${entry.slug}/`);
                            return (
                                <a href={link} class="px-3 py-1 bg-[var(--primary)] text-white dark:text-black rounded-lg text-sm hover:brightness-110 transition">
                                    {getTranslation(l)?.[I18nKey.name] || l}
                                </a>
                            );
                        })}
                    </div>
                </div>
            )}

            {!(entry.isFallback && entry.originalLang !== siteConfig.lang) && (
                <Markdown class="mb-6 markdown-content onload-animation">
                    <Content />
                </Markdown>
            )}

            {licenseConfig.enable && <License title={entry.data.title} slug={entry.slug} pubDate={entry.data.published} class="mb-6 rounded-xl license-container onload-animation"></License>}

        </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between mb-4 gap-4 overflow-hidden w-full">
        <a href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.prevSlug}]}>
            {entry.data.prevSlug && <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-start gap-4" >
                <Icon name="material-symbols:chevron-left-rounded" class="text-[2rem] text-[var(--primary)]" />
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                    {entry.data.prevTitle}
                </div>
            </div>}
        </a>

        <a href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.nextSlug}]}>
            {entry.data.nextSlug && <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-end gap-4">
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                    {entry.data.nextTitle}
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-[2rem] text-[var(--primary)]" />
            </div>}
        </a>
    </div>

    {giscusConfig.enable && <Giscus term={entry.slug} lang={(Astro.params.lang || siteConfig.lang).replace('_', '-')} />}

</MainGridLayout>
