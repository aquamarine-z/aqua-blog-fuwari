---
import { getLangPaths } from '@utils/i18n-utils';
import type { GetStaticPaths } from "astro";
import Pagination from "../../../components/control/Pagination.astro";
import PostPage from "../../../components/PostPage.astro";
import { PAGE_SIZE } from "../../../constants/constants";
import MainGridLayout from "../../../layouts/MainGridLayout.astro";
import { getSortedBlogPosts } from "../../../utils/content-utils";
import { siteConfig } from "../../../config";

export const getStaticPaths = (async ({ paginate }) => {
	const langPaths = getLangPaths();
	return Promise.all(langPaths.map(async (lang) => {
		const langCode = lang.params.lang || siteConfig.lang;
		const posts = await getSortedBlogPosts(langCode);
		return paginate(posts, { pageSize: PAGE_SIZE, params: { lang: lang.params.lang || undefined } });
	})).then(results => results.flat());
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page } = Astro.props;

const len = page.data.length;
---

<MainGridLayout>
    <PostPage page={page}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
</MainGridLayout>