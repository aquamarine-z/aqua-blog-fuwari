                </div>
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
                        <Icon name="material-symbols:rocket-launch-outline-rounded" class="text-lg" />
                    </div>
                    <span class="font-medium text-90 group-hover/tech:text-[var(--primary)] transition-colors duration-300">Astro</span>
                </div>
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
                        <Icon name="fa6-brands:node-js" class="text-lg" />
                    </div>
                    <span class="font-medium text-90 group-hover/tech:text-[var(--primary)] transition-colors duration-300">Node.js</span>
                </div>
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
                        <svg role="img" viewBox="0 0 24 24" class="w-[1.125rem] h-[1.125rem] fill-current" xmlns="http://www.w3.org/2000/svg">
                            <path d="M14.314 0L2.3 12 6 15.7 21.684.013h-7.357zm.014 11.072L7.857 17.53l6.47 6.47H21.7l-6.46-6.468 6.46-6.46h-7.37z"/>
                        </svg>
                    </div>
                    <span class="font-medium text-90 group-hover/tech:text-[var(--primary)] transition-colors duration-300">Flutter</span>
                </div>
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
                        <svg role="img" viewBox="0 0 24 24" class="w-[1.125rem] h-[1.125rem] fill-current" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12.135.003a2.577 2.577 0 0 0-1.42.344L2.55 5.06a2.577 2.577 0 0 0-.953.967l3.957 2.17a1.765 1.765 0 0 1 .603-.588l4.951-2.86a1.761 1.761 0 0 1 1.76 0l4.951 2.86a1.753 1.753 0 0 1 .526.46l3.921-2.265a2.577 2.577 0 0 0-.816-.744L13.291.347a2.577 2.577 0 0 0-1.152-.34Zm-.145 4.912a1.36 1.36 0 0 0-.68.182L6.36 7.953a1.345 1.345 0 0 0-.454.435l1.92 1.055a1.05 1.05 0 0 1 .31-.275l3.34-1.928a1.054 1.054 0 0 1 1.051 0l3.336 1.928a1.066 1.066 0 0 1 .238.199l.018-.01-.002-.002 1.877-1.08a1.353 1.353 0 0 0-.373-.322l-4.95-2.86a1.357 1.357 0 0 0-.68-.178Zm10.432 1.149-3.92 2.26a1.757 1.757 0 0 1 .2.812v5.715c0 .627-.332 1.21-.88 1.528l-4.95 2.86a1.761 1.761 0 0 1-.64.214v4.524a2.577 2.577 0 0 0 1.059-.313l8.162-4.713a2.577 2.577 0 0 0 1.289-2.23V7.297a2.577 2.577 0 0 0-.318-1.228Zm-20.937.238a2.577 2.577 0 0 0-.227.99v9.43c0 .918.491 1.767 1.293 2.229l8.162 4.713a2.57 2.57 0 0 0 1.225.336v-4.531a1.761 1.761 0 0 1-.833-.235L6.156 16.38a1.765 1.765 0 0 1-.877-1.528V9.136a1.776 1.776 0 0 1 .131-.676Zm16.67 2.223-1.89 1.092a1.058 1.058 0 0 1 .124.46v3.856c0 .378-.2.72-.526.907l-3.336 1.93a1.04 1.04 0 0 1-.295.107v2.17c.152-.027.304-.078.44-.157l4.949-2.859a1.36 1.36 0 0 0 .68-1.18V9.136a1.36 1.36 0 0 0-.147-.607Zm-12.387.13a1.36 1.36 0 0 0-.088.481v5.715a1.36 1.36 0 0 0 .68 1.18l4.95 2.86c.194.112.412.166.627.177v-2.174a1.054 1.054 0 0 1-.46-.123L8.14 14.843a1.054 1.054 0 0 1-.532-.908v-3.853a.99.99 0 0 1 .077-.38l-.034-.013z"/>
                        </svg>
                    </div>
                    <span class="font-medium text-90 group-hover/tech:text-[var(--primary)] transition-colors duration-300">Jetpack Compose</span>
                </div>
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
                        <svg role="img" viewBox="0 0 24 24" class="w-[1.125rem] h-[1.125rem] fill-current" xmlns="http://www.w3.org/2000/svg">
                            <path d="M24 0H0v24h24L12.04 11.96 24 0zM12.36 1.18h8.81L.91 22.82V14.01z"/>
                        </svg>
                    </div>
                    <span class="font-medium text-90 group-hover/tech:text-[var(--primary)] transition-colors duration-300">Kotlin</span>
                </div>
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
                        <Icon name="fa6-brands:rust" class="text-lg" />
                    </div>
                    <span class="font-medium text-90 group-hover/tech:text-[var(--primary)] transition-colors duration-300">Rust</span>
                </div>
            </div>
        </div>
        
        <div class="card-base p-8 hover:shadow-lg hover:-translate-y-1 hover:border-[var(--primary)]/10 border border-transparent transition-all duration-300 group flex flex-col gap-y-5 md:grid md:grid-rows-subgrid md:row-span-3">
            <h3 class="text-2xl font-bold flex items-center gap-3 text-[var(--primary)] md:row-start-1">
                <div class="p-2 rounded-lg bg-[var(--primary)]/10 group-hover:bg-[var(--primary)]/20 transition-colors">
                    <Icon name="material-symbols:translate-rounded" class="text-2xl" />
                </div>
                {t(HomeKey.languages)}
            </h3>
            <p class="text-75 leading-relaxed max-w-[65ch] md:row-start-2">
                {t(HomeKey.langDesc)}
            </p>
            <div class="space-y-4 text-75 select-none md:row-start-3">
                <div class="flex items-center gap-4 py-2 group/item">
                    <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 text-[var(--primary)] flex items-center justify-center font-bold text-sm select-none shrink-0 transition-colors duration-300 group-hover/item:bg-[var(--primary)]/20">
                        中
                    </div>
                    <div class="flex flex-col">
                        <span class="font-bold text-90 text-base leading-snug group-hover/item:text-[var(--primary)] transition-colors duration-300">{splitLang(t(HomeKey.native))[0]}</span>
                        <span class="text-xs text-50 leading-none mt-1">{splitLang(t(HomeKey.native))[1]}</span>
                    </div>
                </div>
                <div class="flex items-center gap-4 py-2 group/item">
                    <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 text-[var(--primary)] flex items-center justify-center font-bold text-sm select-none shrink-0 transition-colors duration-300 group-hover/item:bg-[var(--primary)]/20">
                        あ
                    </div>
                    <div class="flex flex-col">
                        <span class="font-bold text-90 text-base leading-snug group-hover/item:text-[var(--primary)] transition-colors duration-300">{splitLang(t(HomeKey.japanese))[0]}</span>
                        <span class="text-xs text-50 leading-none mt-1">{splitLang(t(HomeKey.japanese))[1]}</span>
                    </div>
                </div>
                <div class="flex items-center gap-4 py-2 group/item">
                    <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 text-[var(--primary)] flex items-center justify-center font-bold text-sm select-none shrink-0 transition-colors duration-300 group-hover/item:bg-[var(--primary)]/20">
                        한
                    </div>
                    <div class="flex flex-col">
                        <span class="font-bold text-90 text-base leading-snug group-hover/item:text-[var(--primary)] transition-colors duration-300">{splitLang(t(HomeKey.korean))[0]}</span>
                        <span class="text-xs text-50 leading-none mt-1">{splitLang(t(HomeKey.korean))[1]}</span>
                    </div>
                </div>
                <div class="flex items-center gap-4 py-2 group/item">
                    <div class="w-8 h-8 rounded-lg bg-[var(--primary)]/10 text-[var(--primary)] flex items-center justify-center font-bold text-sm select-none shrink-0 transition-colors duration-300 group-hover/item:bg-[var(--primary)]/20">
                        En
                    </div>
                    <div class="flex flex-col">
                        <span class="font-bold text-90 text-base leading-snug group-hover/item:text-[var(--primary)] transition-colors duration-300">{splitLang(t(HomeKey.english))[0]}</span>
                        <span class="text-xs text-50 leading-none mt-1">{splitLang(t(HomeKey.english))[1]}</span>
