                        <Icon name="material-symbols:code-rounded" class="text-lg" />
                    </div>
                    <span class="font-medium text-90 group-hover/tech:text-[var(--primary)] transition-colors duration-300">TypeScript</span>
                </div>
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
                        <Icon name="material-symbols:palette-outline" class="text-lg" />
                    </div>
