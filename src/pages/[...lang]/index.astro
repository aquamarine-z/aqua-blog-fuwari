                <div class="p-2 rounded-lg bg-[var(--primary)]/10 group-hover:bg-[var(--primary)]/20 transition-colors">
                    <Icon name="material-symbols:code-blocks-outline-rounded" class="text-2xl" />
                </div>
                {t(HomeKey.techStack)}
            </h3>
            <p class="text-75 leading-relaxed max-w-[65ch] md:row-start-2">
                {t(HomeKey.techDesc)}
            </p>
            <div class="grid grid-cols-2 gap-y-4 gap-x-6 md:row-start-3">
                <div class="flex items-center gap-3.5 group/tech select-none py-1 cursor-default">
                    <div class="text-75 group-hover/tech:text-[var(--primary)] group-hover/tech:scale-110 transition-all duration-300">
