---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { getLangPaths } from "@utils/i18n-utils";
export function getStaticPaths() {
	return getLangPaths();
}

import { Icon } from "astro-icon/components";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import { profileConfig, siteConfig } from "../../config";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { url } from "../../utils/url-utils";

const lang = Astro.currentLocale || siteConfig.lang;

import { HomeKey } from "../../i18n/partials/home/keys";

const t = (key: HomeKey) => i18n(key, lang);

const splitLang = (str: string) => {
	const idx = str.indexOf("(");
	if (idx === -1) return [str, ""];
	return [
		str.substring(0, idx).trim(),
		str.substring(idx + 1, str.length - 1).trim(),
	];
};
---

<MainGridLayout title={i18n(I18nKey.home, Astro.currentLocale)}>
    <div class="flex w-full rounded-[var(--radius)] overflow-hidden relative mb-6">
        <div class="card-base z-10 px-6 py-10 md:px-12 md:py-16 relative w-full flex flex-col md:flex-row gap-8 md:gap-12 items-center md:items-start transition-all">
            <div class="w-36 h-36 md:w-52 md:h-52 shrink-0 rounded-full overflow-hidden border-[6px] border-[var(--primary)]/20 shadow-xl shadow-[var(--primary)]/10 hover:scale-105 hover:border-[var(--primary)]/40 hover:shadow-[0_0_20px_var(--primary)]/25 transition-all duration-300">
                <ImageWrapper src={profileConfig.avatar || '/favicon.svg'} alt="Avatar" class="w-full h-full object-cover" />
            </div>
            
            <div class="flex-1 flex flex-col items-center md:items-start gap-5 text-center md:text-left mt-2">
                <h1 class="text-3xl md:text-5xl title-font font-bold text-[var(--primary)] tracking-tight">
                    {t(HomeKey.title)}
                </h1>
                
                <h2 class="text-base md:text-xl font-semibold text-90 min-h-[3rem] md:min-h-[3.5rem] h-auto flex items-start w-full max-w-[65ch] overflow-hidden select-none whitespace-normal">
                    <span id="typewriter" class="border-r-[3px] border-[var(--primary)] pr-1 animate-pulse break-words"></span>
                </h2>
                
                <div class="flex flex-col gap-3 text-base md:text-lg text-75 leading-relaxed max-w-[65ch] text-pretty">
                    <p set:html={t(HomeKey.description)}></p>
                    <p set:html={t(HomeKey.description2)}></p>
                </div>
                
                <div class="flex flex-wrap justify-center md:justify-start gap-3 mt-2 select-none">
                    <div class="flex items-center gap-2.5 px-4 py-2 rounded-xl bg-[var(--primary)]/5 text-[var(--primary)] hover:bg-[var(--primary)]/15 hover:text-[var(--primary)] hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-300 font-medium cursor-default group/chip">
                        <Icon name="fa6-brands:react" class="text-lg text-[var(--primary)]/70 group-hover/chip:text-[var(--primary)] group-hover/chip:scale-110 transition-all duration-300" />
                        <span>React</span>
                    </div>
                    <div class="flex items-center gap-2.5 px-4 py-2 rounded-xl bg-[var(--primary)]/5 text-[var(--primary)] hover:bg-[var(--primary)]/15 hover:text-[var(--primary)] hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-300 font-medium cursor-default group/chip">
                        <Icon name="fa6-brands:vuejs" class="text-lg text-[var(--primary)]/70 group-hover/chip:text-[var(--primary)] group-hover/chip:scale-110 transition-all duration-300" />
                        <span>Vue</span>
                    </div>
                    <div class="flex items-center gap-2.5 px-4 py-2 rounded-xl bg-[var(--primary)]/5 text-[var(--primary)] hover:bg-[var(--primary)]/15 hover:text-[var(--primary)] hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-300 font-medium cursor-default group/chip">
                        <Icon name="material-symbols:palette-outline" class="text-lg text-[var(--primary)]/70 group-hover/chip:text-[var(--primary)] group-hover/chip:scale-110 transition-all duration-300" />
                        <span>{t(HomeKey.design)}</span>
                    </div>
                    <div class="flex items-center gap-2.5 px-4 py-2 rounded-xl bg-[var(--primary)]/5 text-[var(--primary)] hover:bg-[var(--primary)]/15 hover:text-[var(--primary)] hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-300 font-medium cursor-default group/chip">
                        <Icon name="material-symbols:translate-rounded" class="text-lg text-[var(--primary)]/70 group-hover/chip:text-[var(--primary)] group-hover/chip:scale-110 transition-all duration-300" />
                        <span>JLPT N1 & TOPIK 6</span>
                    </div>
                </div>

                <div class="flex flex-wrap gap-4 mt-6 w-full justify-center md:justify-start">
                    <a href={url(Astro.currentLocale && Astro.currentLocale !== siteConfig.lang ? `/${Astro.currentLocale}/blog/` : "/blog/")} class="group bg-[var(--primary)] text-white px-6 py-3.5 rounded-xl hover:brightness-110 shadow-lg shadow-[var(--primary)]/30 active:scale-[0.98] transition-all font-bold flex items-center gap-2 text-lg">
                        <Icon name="material-symbols:article-outline-rounded" class="text-xl" />
                        {t(HomeKey.readBlog)}
                        <Icon name="material-symbols:arrow-forward-rounded" class="text-xl transition-transform group-hover:translate-x-1" />
                    </a>
                    <a href={url(Astro.currentLocale && Astro.currentLocale !== siteConfig.lang ? `/${Astro.currentLocale}/docs/intro/` : "/docs/intro/")} class="group bg-[var(--btn-regular-bg)] text-[var(--primary)] px-6 py-3.5 rounded-xl hover:bg-[var(--btn-regular-bg-hover)] shadow-md active:scale-[0.98] transition-all font-bold flex items-center gap-2 text-lg">
                        <Icon name="material-symbols:menu-book-outline-rounded" class="text-xl" />
                        {t(HomeKey.viewDocs)}
                        <Icon name="material-symbols:arrow-forward-rounded" class="text-xl transition-transform group-hover:translate-x-1" />
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 md:grid-rows-[auto_auto_1fr] gap-6">
        <div class="card-base p-8 hover:shadow-lg hover:-translate-y-1 hover:border-[var(--primary)]/10 border border-transparent transition-all duration-300 group flex flex-col gap-y-5 md:grid md:grid-rows-subgrid md:row-span-3">
