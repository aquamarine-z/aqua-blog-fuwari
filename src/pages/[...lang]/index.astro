const currentT = t[lang as keyof typeof t] || t.zh_CN;
---

<MainGridLayout title="Home">
    <div class="flex w-full rounded-[var(--radius)] overflow-hidden relative mb-6">
        <div class="card-base z-10 px-6 py-10 md:px-12 md:py-16 relative w-full flex flex-col md:flex-row gap-8 md:gap-12 items-center md:items-start transition-all">
            <div class="w-36 h-36 md:w-52 md:h-52 shrink-0 rounded-full overflow-hidden border-[6px] border-[var(--primary)]/20 shadow-xl shadow-[var(--primary)]/10 hover:scale-105 hover:border-[var(--primary)]/40 transition-all duration-300">
                <ImageWrapper src={profileConfig.avatar || '/favicon.svg'} alt="Avatar" class="w-full h-full object-cover" />
            </div>
            
            <div class="flex-1 flex flex-col items-center md:items-start gap-5 text-center md:text-left mt-2">
                <h1 class="text-3xl md:text-5xl font-bold text-[var(--primary)] tracking-tight">
                    {currentT.title} <span class="wave-emoji inline-block origin-bottom-right hover:animate-wiggle cursor-default">👋</span>
                </h1>
                
                <h2 class="text-xl md:text-2xl font-semibold text-90">
                    {currentT.subtitle}
                </h2>
                
                <p class="text-base md:text-lg text-75 leading-relaxed max-w-2xl" set:html={currentT.description}>
                </p>
                
                <div class="flex flex-wrap justify-center md:justify-start gap-3 mt-2">
                    <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 hover:-translate-y-0.5 transition-all font-medium cursor-default">
                        <Icon name="fa6-brands:react" class="text-xl" /> React
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 hover:-translate-y-0.5 transition-all font-medium cursor-default">
                        <Icon name="fa6-brands:vuejs" class="text-xl" /> Vue
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 hover:-translate-y-0.5 transition-all font-medium cursor-default">
                        <Icon name="material-symbols:palette-outline" class="text-xl" /> {currentT.design}
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 hover:-translate-y-0.5 transition-all font-medium cursor-default">
                        <Icon name="material-symbols:translate-rounded" class="text-xl" /> JLPT N1 & TOPIK 6
                    </div>
                </div>

                <div class="flex flex-wrap gap-4 mt-6 w-full justify-center md:justify-start">
                    <a href={Astro.currentLocale && Astro.currentLocale !== siteConfig.lang ? `/${Astro.currentLocale}/blog/` : "/blog/"} class="bg-[var(--primary)] text-white px-6 py-3.5 rounded-xl hover:brightness-110 hover:-translate-y-1 shadow-lg shadow-[var(--primary)]/30 active:scale-95 transition-all font-bold flex items-center gap-2 text-lg">
                        <Icon name="material-symbols:article-outline-rounded" class="text-xl" />
                        {currentT.readBlog}
                    </a>
                    <a href={Astro.currentLocale && Astro.currentLocale !== siteConfig.lang ? `/${Astro.currentLocale}/docs/` : "/docs/"} class="bg-[var(--btn-regular-bg)] text-[var(--btn-content)] px-6 py-3.5 rounded-xl hover:bg-[var(--btn-hover-bg)] hover:-translate-y-1 shadow-md active:scale-95 transition-all font-bold flex items-center gap-2 text-lg">
                        <Icon name="material-symbols:menu-book-outline-rounded" class="text-xl" />
                        {currentT.viewDocs}
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="card-base p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
            <h3 class="text-2xl font-bold mb-5 flex items-center gap-3 text-[var(--primary)]">
                <div class="p-2 rounded-lg bg-[var(--primary)]/10 group-hover:bg-[var(--primary)]/20 transition-colors">
                    <Icon name="material-symbols:code-blocks-outline-rounded" class="text-2xl" />
                </div>
                {currentT.techStack}
            </h3>
            <p class="text-75 mb-5 leading-relaxed">
                {currentT.techDesc}
            </p>
            <ul class="space-y-2 text-75">
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> React, Vue.js, Svelte</li>
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> Tailwind CSS, SCSS</li>
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> TypeScript, Node.js</li>
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> Astro, Next.js, Nuxt</li>
            </ul>
        </div>
        
        <div class="card-base p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
            <h3 class="text-2xl font-bold mb-5 flex items-center gap-3 text-[var(--primary)]">
                <div class="p-2 rounded-lg bg-[var(--primary)]/10 group-hover:bg-[var(--primary)]/20 transition-colors">
                    <Icon name="material-symbols:translate-rounded" class="text-2xl" />
                </div>
                {currentT.languages}
            </h3>
            <p class="text-75 mb-5 leading-relaxed">
                {currentT.langDesc}
            </p>
            <ul class="space-y-2 text-75">
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> {currentT.native}</li>
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> {currentT.english}</li>
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> {currentT.japanese}</li>
                <li class="flex items-center gap-3"><Icon name="material-symbols:check-circle-outline-rounded" class="text-[var(--primary)]" /> {currentT.korean}</li>
            </ul>
        </div>
    </div>
</MainGridLayout>

<style>
@keyframes wiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-20deg); }
    50% { transform: rotate(20deg); }
    75% { transform: rotate(-10deg); }
}
.hover\:animate-wiggle:hover {
    animation: wiggle 1s ease-in-out infinite;
}
</style>
