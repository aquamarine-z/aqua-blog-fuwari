---
import { getLangPaths } from '@utils/i18n-utils';
import { siteConfig } from "../../config";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
	const langPaths = getLangPaths();
	return Promise.all(langPaths.map(async (lang) => {
		const langCode = lang.params.lang || siteConfig.lang;
		const sortedPostsList = await getSortedBlogPostsList(langCode);
		return {
			params: { lang: lang.params.lang || undefined },
			props: { sortedPostsList }
		};
	}));
}) satisfies GetStaticPaths;

import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedBlogPostsList } from "../../utils/content-utils";

const { sortedPostsList } = Astro.props;
---

<MainGridLayout title={i18n(I18nKey.archive, Astro.currentLocale)}>
    <ArchivePanel sortedPosts={sortedPostsList} client:only="svelte" lang={Astro.currentLocale}></ArchivePanel>
</MainGridLayout>
