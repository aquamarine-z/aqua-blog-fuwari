---
import { getLangPaths } from "@utils/i18n-utils";
import type { GetStaticPaths } from "astro";
import { siteConfig } from "../../config";

export const getStaticPaths = (async () => {
	const langPaths = getLangPaths();
	return Promise.all(
		langPaths.map(async (lang) => {
			const langCode = lang.params.lang || siteConfig.lang;
			const sortedPostsList = await getSortedBlogPostsList(langCode);
			const sortedDocsList = await getSortedDocsPostsList(langCode);
			return {
				params: { lang: lang.params.lang || undefined },
				props: { sortedPostsList, sortedDocsList },
			};
		}),
	);
}) satisfies GetStaticPaths;

import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getSortedBlogPostsList,
	getSortedDocsPostsList,
} from "../../utils/content-utils";

const { sortedPostsList, sortedDocsList } = Astro.props;
---

<MainGridLayout title={i18n(I18nKey.archive, Astro.currentLocale)}>
    <ArchivePanel blogPosts={sortedPostsList} docsPosts={sortedDocsList} client:only="svelte" lang={Astro.currentLocale}></ArchivePanel>
</MainGridLayout>
